# PharmaOS — environment template (copy to .env and fill in).
# Structure follows CLAUDE.md "ملفات الإعداد المطلوبة".
#
# ⚠️ Secrets policy (CLAUDE.md):
#   .env holds ONLY paths, database names, non-secret settings and key REFERENCES.
#   On production devices the critical secrets live in the OS keystore, never here:
#     JWT_PRIVATE_KEY / JWT_PUBLIC_KEY   -> OS keystore (safeStorage / DPAPI / keyring)
#     ENCRYPTION_KEY                     -> OS keystore
#     ETA_CLIENT_SECRET + seal cert      -> OS keystore
#     SUPABASE_SERVICE_ROLE_KEY          -> cloud only (never on the pharmacy device)

# --- Local infrastructure (docker compose) ---
POSTGRES_DB=pharmaos
POSTGRES_USER=pharmaos
POSTGRES_PASSWORD=change-me-strong-password

# --- Application ---
DATABASE_URL=postgresql://pharmaos:change-me-strong-password@localhost:5432/pharmaos
REDIS_URL=redis://localhost:6379

# --- Cloud (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Backup ---
BACKUP_PATH=/var/pharmaos/backups
BACKUP_CLOUD_BUCKET=

# --- Country / currency defaults ---
COUNTRY_CODE=EG
DEFAULT_CURRENCY=EGP

# --- Receipt printer (P1-M9, device-local) ---
# Network ESC/POS printer (JetDirect). Leave PRINTER_HOST empty if none is
# attached — the POS UI falls back to browser printing.
PRINTER_HOST=
PRINTER_PORT=9100

# --- Egypt compliance (filled at activation, Phase 2) ---
ETA_API_BASE=
ETA_CLIENT_ID=
EDA_TT_API_BASE=
