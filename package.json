{
  "name": "pharmaos",
  "version": "1.1.0",
  "private": true,
  "description": "PharmaOS — hybrid (offline-first + cloud) pharmacy management system. Monorepo root.",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "9.17.0",
    "eslint": "9.17.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.11",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}": "prettier --write",
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix"
  }
}
